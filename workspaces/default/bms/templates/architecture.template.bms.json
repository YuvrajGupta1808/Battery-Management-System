            { "id": "i2c_sda", "label": "I2C_SDA", "side": "top" },
            { "id": "i2c_scl", "label": "I2C_SCL", "side": "top" },
            { "id": "bal_out", "label": "BAL_OUT", "side": "right" }
          ]
        },
        {

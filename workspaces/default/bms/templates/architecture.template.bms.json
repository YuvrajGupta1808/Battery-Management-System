{
  "schema_version": "1.0",
  "template_meta": {
    "purpose": "Reference skeleton for agents — copy to bms/architecture.bms.json and customize",
    "do_not_edit_in_place": true,
    "output_file": "bms/architecture.bms.json",
    "generation_checklist": [
      "Set pack.topology, cell_count (= series × parallel), chemistry, nominal_voltage_v",
      "Reshape schematic per topology — not metadata-only: cell stack width/label, AFE CELL_1-N pins, busbars for 2p+",
      "views.pack: include cells, bms_board (drill_view bms), contactor; add cooling/busbars if relevant",
      "views.bms: include mcu, cell_monitor_ic, temperature_network, balancing, current_sensor, can_transceiver, memory",
      "Every node: id, type, label, x, y, width (>=40), height (>=30), pins[] with id/label/side",
      "edges: connect pins with from_node, from_pin, to_node, to_pin, signal",
      "components: real part numbers (e.g. BQ76952, STM32F407, MCP2551, INA226)",
      "Create bms/safety_rules.yaml with thermal, OVP, UVP, OCP rules linked to component mcu"
    ],
    "pack_view_required_types": ["cells", "bms_board", "contactor"],
    "pack_view_optional_types": ["cooling", "busbars", "load"],
    "bms_view_required_types": [
      "mcu",
      "cell_monitor_ic",
      "temperature_network",
      "balancing",
      "current_sensor",
      "can_transceiver",
      "memory"
    ],
    "example_topologies": {
      "4s1p": { "cell_count": 4, "nominal_voltage_v": 14.8 },
      "12s2p": { "cell_count": 24, "nominal_voltage_v": 44.4 },
      "16s4p": { "cell_count": 64, "nominal_voltage_v": 59.2 }
    }
  },
  "pack": {
    "topology": "4s1p",
    "cell_count": 4,
    "chemistry": "NMC",
    "nominal_voltage_v": 14.8
  },
  "views": {
    "pack": {
      "nodes": [
        {
          "id": "cells",

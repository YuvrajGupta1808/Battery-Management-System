          "height": 80,
          "pins": [
            { "id": "bneg", "label": "B-", "side": "left" },
            { "id": "bpos", "label": "B+", "side": "right" }
          ]
        },
        {
          "id": "cooling",
          "type": "cooling",
          "label": "Cooling Fan",
          "x": 360,
          "y": 80,
          "width": 120,
          "height": 70,
          "pins": [{ "id": "fan_pwr", "label": "FAN_PWR", "side": "bottom" }]
        },
        {
          "id": "bms_board",
          "type": "bms_board",
          "label": "BMS Board",
          "x": 340,
          "y": 260,
          "width": 160,
          "height": 120,
          "drill_view": "bms",
          "pins": [
            { "id": "pack_pos", "label": "PACK+", "side": "left" },
            { "id": "pack_neg", "label": "PACK-", "side": "left" },
            { "id": "can_bus", "label": "CAN", "side": "right" },
            { "id": "fan_ctrl", "label": "FAN_CTRL", "side": "top" }
          ]
        },
        {
          "id": "contactor",
          "type": "contactor",
          "label": "Contactor",
          "x": 560,
          "y": 280,
          "width": 100,
          "height": 80,
          "pins": [
            { "id": "batt_in", "label": "BATT_IN", "side": "left" },
            { "id": "load", "label": "LOAD", "side": "right" }
          ]
        }
      ],
      "edges": [
        { "from_node": "cells", "from_pin": "bpos", "to_node": "bms_board", "to_pin": "pack_pos", "signal": "PACK+" },
        { "from_node": "cells", "from_pin": "bneg", "to_node": "bms_board", "to_pin": "pack_neg", "signal": "PACK-" },
        { "from_node": "bms_board", "from_pin": "pack_pos", "to_node": "contactor", "to_pin": "batt_in", "signal": "MAIN+" },
        { "from_node": "bms_board", "from_pin": "fan_ctrl", "to_node": "cooling", "to_pin": "fan_pwr", "signal": "FAN_CTRL" }
      ]
    },

          "y": 340,
          "width": 140,
          "height": 70,
          "component_ref": "current_sensor",
          "pins": [
            { "id": "shunt", "label": "SHUNT", "side": "left" },
            { "id": "i2c_sda", "label": "I2C_SDA", "side": "top" }
          ]
        },
        {
          "id": "can",
          "type": "can_transceiver",
          "label": "CAN Transceiver",
          "x": 520,
          "y": 40,
          "width": 140,
          "height": 70,
          "component_ref": "can_transceiver",
          "pins": [
            { "id": "tx", "label": "TX", "side": "left" },
            { "id": "can_h", "label": "CAN_H", "side": "right" }
          ]
        },
        {
          "id": "memory",
          "type": "memory",
          "label": "EEPROM / Flash",
          "x": 520,
          "y": 420,
          "width": 140,
          "height": 70,
          "component_ref": "memory",
          "pins": [{ "id": "spi", "label": "SPI", "side": "left" }]
        }
      ],
      "edges": [
        { "from_node": "mcu", "from_pin": "i2c_sda", "to_node": "cell_ic", "to_pin": "i2c_sda", "signal": "I2C_SDA" },
        { "from_node": "mcu", "from_pin": "i2c_scl", "to_node": "cell_ic", "to_pin": "i2c_scl", "signal": "I2C_SCL" },
        { "from_node": "mcu", "from_pin": "i2c_sda", "to_node": "temp_net", "to_pin": "i2c_sda", "signal": "I2C_SDA" },
        { "from_node": "cell_ic", "from_pin": "bal_out", "to_node": "balancing", "to_pin": "bal_in", "signal": "BAL_CTRL" },
        { "from_node": "mcu", "from_pin": "can_tx", "to_node": "can", "to_pin": "tx", "signal": "CAN_TX" },
        { "from_node": "mcu", "from_pin": "spi_mosi", "to_node": "memory", "to_pin": "spi", "signal": "SPI_MOSI" }
      ]
    }
  },
  "components": {
    "mcu": { "part": "STM32F407", "role": "protection_logic" },
    "cell_monitor_0": { "part": "BQ76952", "cells_monitored": 4 },
    "temp_network": { "part": "NTC Array", "sensor_count": 4 },
    "balancing": { "part": "Passive Balancing", "mode": "passive" },
    "current_sensor": { "part": "INA226", "shunt_mohm": 0.5 },
    "can_transceiver": { "part": "MCP2551" },
    "memory": { "part": "AT24C256", "role": "firmware_storage" }
  }
}

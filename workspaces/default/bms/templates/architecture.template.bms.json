          "pins": [
            { "id": "ntc", "label": "NTC_1-4", "side": "left" },
            { "id": "i2c_sda", "label": "I2C_SDA", "side": "top" }
          ]
        },
        {
          "id": "balancing",
          "type": "balancing",

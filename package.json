{
  "name": "battery-management-system",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "concurrently -n backend,web -c cyan,green \"pnpm dev:backend\" \"pnpm dev:web\"",
    "dev:backend": "WORKBENCH_DEFAULT_MODEL=openai:accounts/fireworks/models/qwen3p6-plus PYTHONPATH=backend/src .venv/bin/python -m uvicorn agent_workbench.main:app --host 127.0.0.1 --port 8000 --reload",
    "dev:web": "VITE_API_BASE_URL=http://127.0.0.1:8000 pnpm --dir apps/web dev --host 127.0.0.1 --port 5173 --strictPort",
    "test": "pnpm test:backend && pnpm test:web",
    "test:backend": "PYTHONPATH=backend/src .venv/bin/python -m pytest backend/tests",
    "test:web": "pnpm --dir apps/web test",
    "build:web": "pnpm --dir apps/web build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}

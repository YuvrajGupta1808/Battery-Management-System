WORKBENCH_TOKEN=dev-local-token
WORKBENCH_WORKSPACE_ROOT=/Users/Yuvraj/Battery-Management-System/workspaces
WORKBENCH_ALLOWED_ROOTS=/Users/Yuvraj/Battery-Management-System/workspaces
WORKBENCH_DEFAULT_MODEL=openai:accounts/fireworks/models/glm-4p7
WORKBENCH_LANGSMITH_TRACING=false

# Optional provider keys. The app runs without these in mock mode.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
BASETEN_API_KEY=
TAVILY_API_KEY=
FIREWORKS_API_KEY=
OPENAI_BASE_URL=https://api.fireworks.ai/inference/v1

# Optional remote sandbox placeholder. Remote sandbox mode is disabled until set.
WORKBENCH_REMOTE_SANDBOX_URL=
WORKBENCH_REMOTE_SANDBOX_TOKEN=

# Opsera DevSecOps MCP (Deep Agent tools).
# Cursor MCP uses browser sign-in automatically — no token in .cursor/mcp.json.
# For CANary Deep Agent chat, run once: make opsera-login
WORKBENCH_OPSERA_ENABLED=true
OPSERA_API_TOKEN=
OPSERA_MCP_URL=https://agent.opsera.ai/mcp
# Optional: override OAuth token file (default: .data/opsera-oauth.json)
WORKBENCH_OPSERA_OAUTH_PATH=
# Repository root for Opsera scans (defaults to auto-detect from workspace)
WORKBENCH_OPSERA_SCAN_ROOT=
